generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id              String   @id @default(cuid())
  topic           String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  themeId         String   @default("dark")
  themeBackground String   @default("#0f172a")
  themeText       String   @default("#f1f5f9")
  themeAccent     String   @default("#3b82f6")
  themeHeading    String   @default("#ffffff")
  themeName       String   @default("Dark")
  brandName       String?
  brandHandle     String?
  brandImage      String?
  slides          Slide[]
}

model Slide {
  id                     String  @id @default(cuid())
  projectId              String
  index                  Int
  heading                String
  body                   String
  bodyShort              String?
  bodyLong               String?
  suggestedImage         String
  tone                   String  @default("educational")
  minTextVersion         String  @default("")
  maxTextVersion         String  @default("")
  backgroundImageUrl     String?
  layout                 String?
  useExtendedDescription Boolean @default(false)
  customTexts            String? // JSON string for custom text elements
  project                Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}
